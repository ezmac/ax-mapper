{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ax-mapper-output",
  "title": "AX Mapper Course Export",
  "description": "Autocross course layout exported by ax-mapper. Structurally compatible with cone_data.schema.json. All positions are in Blender/world space: bx = east (metres), by = north (metres, +Y up).",
  "type": "object",
  "required": [
    "transform",
    "pointer_source",
    "n_standing", "n_pointer", "n_timing_start", "n_timing_end", "n_gcp",
    "bounds",
    "standing", "pointers", "timing_start", "timing_end", "gcp"
  ],
  "additionalProperties": false,
  "properties": {
    "transform": {
      "description": "Uniform-scale coordinate transform. bx = scale*cx + ox; by = -scale*cy + oy (canvas Y flipped to world +Y up).",
      "type": "object",
      "required": ["type", "scale", "ox", "oy"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "scale"
        },
        "scale": {
          "description": "Metres per canvas unit (scaleMetresPerUnit).",
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ox": {
          "description": "X origin offset (metres). Always 0 in current exports.",
          "type": "number"
        },
        "oy": {
          "description": "Y origin offset (metres). Always 0 in current exports.",
          "type": "number"
        }
      }
    },

    "pointer_source": {
      "description": "Colour used to render pointer cones.",
      "type": "string",
      "enum": ["magenta", "orange"]
    },

    "n_standing":     { "type": "integer", "minimum": 0, "description": "Count of standing (orange) cones." },
    "n_pointer":      { "type": "integer", "minimum": 0, "description": "Count of pointer (directional) cones." },
    "n_timing_start": { "type": "integer", "minimum": 0, "description": "Count of timing-start (green) cones." },
    "n_timing_end":   { "type": "integer", "minimum": 0, "description": "Count of timing-end (red) cones." },
    "n_gcp":          { "type": "integer", "minimum": 0, "description": "Count of GCP (blue) cones." },

    "bounds": {
      "description": "Axis-aligned bounding box of all cone centres in world space (metres). All four values are 0 when no cones are placed.",
      "type": "object",
      "required": ["xmin", "xmax", "ymin", "ymax"],
      "additionalProperties": false,
      "properties": {
        "xmin": { "type": "number" },
        "xmax": { "type": "number" },
        "ymin": { "type": "number" },
        "ymax": { "type": "number" }
      }
    },

    "standing": {
      "description": "Standing (orange) cone entries.",
      "type": "array",
      "items": { "$ref": "#/$defs/base_cone" }
    },
    "pointers": {
      "description": "Pointer (directional) cone entries.",
      "type": "array",
      "items": { "$ref": "#/$defs/pointer_cone" }
    },
    "timing_start": {
      "description": "Timing-start (green) cone entries.",
      "type": "array",
      "items": { "$ref": "#/$defs/base_cone" }
    },
    "timing_end": {
      "description": "Timing-end (red) cone entries.",
      "type": "array",
      "items": { "$ref": "#/$defs/base_cone" }
    },
    "gcp": {
      "description": "GCP (blue) cone entries.",
      "type": "array",
      "items": { "$ref": "#/$defs/base_cone" }
    }
  },

  "$defs": {
    "base_cone": {
      "description": "A single placed cone.",
      "type": "object",
      "required": ["bx", "by", "type", "size"],
      "additionalProperties": false,
      "properties": {
        "bx":   { "type": "number",  "description": "Blender X coordinate (metres, east positive)." },
        "by":   { "type": "number",  "description": "Blender Y coordinate (metres, north positive)." },
        "type": {
          "type": "string",
          "enum": ["standing", "timing_start", "timing_end", "gcp"],
          "description": "Cone role."
        },
        "size": { "type": "integer", "minimum": 1, "description": "Cone bounding-box height in canvas units (equals coneSettings.size)." }
      }
    },

    "pointer_cone": {
      "description": "A directional pointer cone.",
      "type": "object",
      "required": ["bx", "by", "type", "size", "facing_deg"],
      "additionalProperties": false,
      "properties": {
        "bx":   { "type": "number", "description": "Blender X coordinate (metres, east positive)." },
        "by":   { "type": "number", "description": "Blender Y coordinate (metres, north positive)." },
        "type": { "type": "string", "const": "pointer" },
        "size": { "type": "integer", "minimum": 1, "description": "Cone bounding-box height in canvas units." },
        "facing_deg": {
          "description": "Direction the pointer tip faces: degrees CCW from east (+X), range [0, 360). Rounded to 2 decimal places.",
          "type": "number",
          "minimum": 0,
          "exclusiveMaximum": 360
        }
      }
    }
  }
}
